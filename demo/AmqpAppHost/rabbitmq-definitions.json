      "name": "pubsub-demo",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "pubsub-demo",
      "vhost": "/",
      "destination": "pubsub-demo.sub1",
